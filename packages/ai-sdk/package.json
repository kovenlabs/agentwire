{
  "name": "@kovenlabs/agentwire-ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK adapter for agentwire: tool conversion + the useAgentChat runtime.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@kovenlabs/agentwire": "workspace:*",
    "@kovenlabs/agentwire-react": "workspace:*",
    "@kovenlabs/agentwire-tools": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^5 || ^6",
    "@ai-sdk/react": "^2 || ^3",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@types/react": "^19.0.1",
    "ai": "^6.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovenlabs/agentwire.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://github.com/kovenlabs/agentwire#readme",
  "bugs": "https://github.com/kovenlabs/agentwire/issues"
}
